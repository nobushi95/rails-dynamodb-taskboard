<h1>Edit Task</h1>
<p style="color: #666; margin-bottom: 16px;">Project: <%= @project&.name %></p>

<div class="card">
  <%= form_with url: project_task_path(params[:project_id], @task.task_id), method: :patch, local: true do |f| %>
    <div class="form-group">
      <label for="title">Title</label>
      <input type="text" name="title" id="title" value="<%= @task.title %>" required>
    </div>
    <div class="form-group">
      <label for="due_date">Due Date</label>
      <input type="date" name="due_date" id="due_date" value="<%= @task.due_date %>" required>
    </div>
    <div class="form-group">
      <label for="assignee_id">Assignee</label>
      <select name="assignee_id" id="assignee_id">
        <option value="">Unassigned</option>
        <% @users.each do |user| %>
          <option value="<%= user.user_id %>" <%= 'selected' if @task.assignee_id == user.user_id %>><%= user.name %></option>
        <% end %>
      </select>
    </div>
    <div class="form-group">
      <label for="priority">Priority</label>
      <select name="priority" id="priority">
        <% Task::PRIORITIES.each do |p| %>
          <option value="<%= p %>" <%= 'selected' if @task.priority == p %>><%= p.capitalize %></option>
        <% end %>
      </select>
    </div>
    <div class="form-group">
      <label for="status">Status</label>
      <select name="status" id="status">
        <% Task::STATUSES.each do |s| %>
          <option value="<%= s %>" <%= 'selected' if @task.status == s %>><%= s.titleize %></option>
        <% end %>
      </select>
    </div>
    <div>
      <%= submit_tag "Update Task", class: "btn btn-primary" %>
      <%= link_to "Cancel", project_path(params[:project_id]), class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>
